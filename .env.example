# ============================================================
# PROMOTION WORKFLOW — Environment Variables
# Copy to .env and populate before running.
# Store all secrets in Union Station environment variables.
# NEVER commit .env to source control.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# The public base URL of this service (used for DocuSign webhook callback).
# On Union Station, set this to your service's external URL.
APP_BASE_URL=https://promotion-workflow.internal.yourcompany.com

# ── Slack ────────────────────────────────────────────────────
# Bot token (xoxb-...) from Slack App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret from Slack App → Basic Information
SLACK_SIGNING_SECRET=your-signing-secret-here

# Jenni's Slack User ID (U...). Find via Slack profile → "Copy Member ID".
# This is the ONLY user authorized to run /promote.
JENNI_SLACK_USER_ID=UXXXXXXXXX

# ── DocuSign ─────────────────────────────────────────────────
# Integration Key (Client ID) from DocuSign Admin → Apps & Keys
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# DocuSign Account ID (found in Admin → Account Settings)
DOCUSIGN_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# DocuSign API base path. Use production or demo:
#   Demo:       https://demo.docusign.net/restapi
#   Production: https://na4.docusign.net/restapi  (check your account region)
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# DocuSign OAuth base path (without https://)
#   Demo:       account-d.docusign.com
#   Production: account.docusign.com
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com

# DocuSign user GUID to impersonate for JWT grant (your sending account's user GUID)
DOCUSIGN_IMPERSONATION_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RSA private key for JWT grant auth, base64-encoded.
# Generate in DocuSign Admin → Apps & Keys → Add RSA Key Pair.
# Encode the private key: base64 -i private.key | tr -d '\n'
DOCUSIGN_PRIVATE_KEY_BASE64=base64encodedprivatekeyhere

# Secret for validating DocuSign Connect webhook HMAC signatures.
# Set in DocuSign Admin → Connect → [your configuration] → HMAC Key.
DOCUSIGN_WEBHOOK_HMAC_KEY=your-docusign-hmac-secret-here

# ── Second Signer ─────────────────────────────────────────────
# Alex Bovee — always signing order 2 on every promotion letter.
ALEX_BOVEE_EMAIL=alex@yourcompany.com
ALEX_BOVEE_NAME=Alex Bovee

# ── Storage ──────────────────────────────────────────────────
# Storage provider: "local" or "s3"
STORAGE_PROVIDER=local

# Base path for local storage (employee folders live under here).
# Example: /var/data/employee-files
STORAGE_LOCAL_BASE_PATH=/var/data/employee-files

# S3 settings (only needed if STORAGE_PROVIDER=s3)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=employee-files/
